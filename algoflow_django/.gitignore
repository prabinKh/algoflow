# ═══════════════════════════════════════════════════════════
# Django Backend .gitignore
# ═══════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════
# PYTHON
# ═══════════════════════════════════════════════════════════

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# ═══════════════════════════════════════════════════════════
# DJANGO
# ═══════════════════════════════════════════════════════════

# Database
*.db
*.sqlite
*.sqlite3
algoflow.db

# Static files
staticfiles/
static_root/

# Media files (user uploads)
media/
user_uploads/

# Logs
logs/
*.log

# Locale
*.mo
*.pot

# Migrations (uncomment if you don't want to track migrations)
# */migrations/*.py
# !*/migrations/__init__.py

# ═══════════════════════════════════════════════════════════
# VIRTUAL ENVIRONMENT
# ═══════════════════════════════════════════════════════════

venv/
env/
ENV/
.venv
ENV/
env.bak/
venv.bak/

# Python version
.python-version

# pipenv
Pipfile.lock

# poetry
poetry.lock

# ═══════════════════════════════════════════════════════════
# TESTING
# ═══════════════════════════════════════════════════════════

# Pytest
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# Nose
nosetests.xml

# Tox
.tox/

# ═══════════════════════════════════════════════════════════
# IDE
# ═══════════════════════════════════════════════════════════

# PyCharm
.idea/
*.iml

# VS Code
.vscode/

# Eclipse
.pydevproject
.settings/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Jupyter Notebook
.ipynb_checkpoints

# Spyder
.spyderproject
.spyproject

# Rope
.ropeproject

# ═══════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════

# Environment variables
.env
.env.local
.env.*.local
.env.development
.env.production

# Secrets
*.pem
*.key
secrets/
credentials/

# AWS
.aws/

# ═══════════════════════════════════════════════════════════
# DJANGO SPECIFIC
# ═══════════════════════════════════════════════════════════

# Celery
celerybeat-schedule
celerybeat.pid

# Daphne
daphne.pid

# Gunicorn
*.pid

# uWSGI
*.pid
*.sock

# ═══════════════════════════════════════════════════════════
# OS
# ═══════════════════════════════════════════════════════════

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ═══════════════════════════════════════════════════════════
# DO NOT IGNORE (Keep these)
# ═══════════════════════════════════════════════════════════

# DO keep these files
!.gitignore
!requirements.txt
!manage.py
!Dockerfile
!*.md
!.env.example
