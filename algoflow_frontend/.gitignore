# ═══════════════════════════════════════════════════════════
# React Frontend .gitignore
# ═══════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════
# DEPENDENCIES
# ═══════════════════════════════════════════════════════════

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Package lock files (keep one based on your package manager)
# package-lock.json  # Keep if using npm
# yarn.lock          # Keep if using yarn
# pnpm-lock.yaml     # Keep if using pnpm

# ═══════════════════════════════════════════════════════════
# BUILD OUTPUTS
# ═══════════════════════════════════════════════════════════

# Build outputs
dist/
build/
out/

# Vite
*.local

# Rollup
.rollup.cache

# Parcel
.parcel-cache/
.cache/

# Webpack
webpack-stats.json
webpack.manifest.json

# ═══════════════════════════════════════════════════════════
# TESTING
# ═══════════════════════════════════════════════════════════

# Test coverage
coverage/
.nyc_output/

# Jest
jest-results.json

# ═══════════════════════════════════════════════════════════
# IDE
# ═══════════════════════════════════════════════════════════

# VS Code
.vscode/
*.code-workspace

# WebStorm
.idea/

# Other IDE files
*.iml
*.ipr
*.iws

# ═══════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════

# Environment variables
.env
.env.local
.env.development
.env.production
.env.test

# Keep example env files
!.env.example

# Secrets
*.pem
*.key
secrets/
credentials/

# ═══════════════════════════════════════════════════════════
# TYPESCRIPT
# ═══════════════════════════════════════════════════════════

# TypeScript cache
*.tsbuildinfo

# TypeScript build outputs
dist/

# ═══════════════════════════════════════════════════════════
# OS
# ═══════════════════════════════════════════════════════════

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ═══════════════════════════════════════════════════════════
# MISCELLANEOUS
# ═══════════════════════════════════════════════════════════

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Cache
.cache/
.eslintcache
.stylelintcache

# Storybook
storybook-static/

# ═══════════════════════════════════════════════════════════
# DO NOT IGNORE (Keep these)
# ═══════════════════════════════════════════════════════════

# DO keep these files
!.gitignore
!package.json
!package-lock.json
!vite.config.ts
!tsconfig.json
!README.md
!Dockerfile
!nginx.conf
!.env.example
